datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

enum Role {
  ADMIN
  STAFF
  APPROVER
  VIEWER
}

enum AssetStatus {
  AVAILABLE
  BORROWED
  MAINTENANCE
  LOST
  RETIRED
}

enum BorrowStatus {
  PENDING
  APPROVED
  REJECTED
  BORROWED
  RETURN_PENDING
  RETURNED
  OVERDUE
  CANCELLED
}

enum ConditionStatus {
  NORMAL
  DAMAGED
  LOST
  INCOMPLETE
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  password         String
  name             String
  role             Role            @default(STAFF)
  employeeId       String?         @unique
  employee         Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  approvedRequests BorrowRequest[] @relation("ApprovedRequests")
  recordedReturns  AssetReturn[]   @relation("RecordedReturns")
  auditLogs        AuditLog[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Employee {
  id             String          @id @default(uuid())
  employeeCode   String          @unique
  firstName      String
  lastName       String
  department     String
  email          String          @unique
  phone          String?
  user           User?
  borrowRequests BorrowRequest[]
  assets         Asset[]         @relation("CurrentHolder")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Asset {
  id                 String          @id @default(uuid())
  assetCode          String          @unique
  name               String
  category           String
  serialNumber       String?
  description        String?
  status             AssetStatus     @default(AVAILABLE)
  currentHolderId    String?
  currentHolder      Employee?       @relation("CurrentHolder", fields: [currentHolderId], references: [id], onDelete: SetNull)
  imageUrl           String?
  cloudinaryPublicId String?
  qrCode             String          @unique
  borrowRequests     BorrowRequest[]
  returns            AssetReturn[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([status])
  @@index([currentHolderId])
}

model BorrowRequest {
  id                 String        @id @default(uuid())
  requestNo          String        @unique
  borrowerId         String
  borrower           Employee      @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  assetId            String
  asset              Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  borrowDate         DateTime
  expectedReturnDate DateTime
  purpose            String
  status             BorrowStatus  @default(PENDING)
  approvedById       String?
  approvedBy         User?         @relation("ApprovedRequests", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt         DateTime?
  rejectedReason     String?
  signature          String?
  assetReturn        AssetReturn?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status])
  @@index([borrowerId])
  @@index([assetId])
  @@index([status, expectedReturnDate])
}

model AssetReturn {
  id                 String          @id @default(uuid())
  borrowRequestId    String          @unique
  borrowRequest      BorrowRequest   @relation(fields: [borrowRequestId], references: [id], onDelete: Cascade)
  assetId            String
  asset              Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  returnDate         DateTime        @default(now())
  condition          ConditionStatus
  conditionNote      String?
  imageUrl           String?
  cloudinaryPublicId String?
  recordedById       String
  recordedBy         User            @relation("RecordedReturns", fields: [recordedById], references: [id], onDelete: Restrict)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([assetId])
  @@index([recordedById])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  oldData    Json?
  newData    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model SystemSetting {
  id                      String   @id @default("default-settings-id")
  companyNameTh           String   @default("บริษัท ไทย อินเตอร์ ฟลายอิ้ง จำกัด")
  companyNameEn           String   @default("Thai Inter Flying Co., Ltd.")
  businessType            String   @default("สถาบันฝึกอบรมการบิน / Aviation Training Academy")
  contactEmail            String   @default("info@tif.ac.th")
  maxBorrowDays           Int      @default(7)
  autoMaintenanceOnDamaged Boolean  @default(true)
  updatedAt               DateTime @updatedAt
}
